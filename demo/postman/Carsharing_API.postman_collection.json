{
  "info": {
    "name": "Carsharing API (Россия)",
    "description": "CRUD и бизнес-операции каршеринга. Данные для России: номера, имена, почта.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Полный сценарий",
      "description": "Создание сущностей → старт поездки → завершение → оплата → проверка",
      "item": [
        {
          "name": "1. Создать автомобиль",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"brand\": \"Lada\",\n  \"model\": \"Vesta\",\n  \"plateNumber\": \"А123ВС77\"\n}"},
            "url": "http://localhost:8080/cars"
          }
        },
        {
          "name": "2. Создать пользователя",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"firstName\": \"Иван\",\n  \"lastName\": \"Петров\",\n  \"email\": \"ivan.petrov@mail.ru\"\n}"},
            "url": "http://localhost:8080/users"
          }
        },
        {
          "name": "3. Начать поездку",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"userId\": 1,\n  \"carId\": 1,\n  \"startTime\": \"28.02.2025 10:00\"\n}"},
            "url": "http://localhost:8080/rides"
          }
        },
        {
          "name": "4. Завершить поездку",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"endTime\": \"28.02.2025 11:30\",\n  \"distance\": 25.5\n}"},
            "url": "http://localhost:8080/rides/1/end"
          }
        },
        {
          "name": "5. Оплатить поездку",
          "request": {"method": "POST", "url": "http://localhost:8080/rides/1/pay"}
        },
        {
          "name": "6. Проверить доход пользователя",
          "request": {"method": "GET", "url": "http://localhost:8080/users/1/income"}
        },
        {
          "name": "7. Список доступных авто",
          "request": {"method": "GET", "url": "http://localhost:8080/cars/available"}
        }
      ]
    },
